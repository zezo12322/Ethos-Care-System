                "html": "<style>.hznav{max-width:1200px;margin:0 auto;padding:1rem 3rem;display:flex;align-items:center;justify-content:space-between;}.hznav a{text-decoration:none;font-family:Poppins,sans-serif;}.hznav__logo{font-size:.9rem;font-weight:700;transition:color .3s;}.hznav__logo:hover{color:var(--hz-green,#20C997);}.hznav__links{display:flex;align-items:center;gap:2rem;}.hznav__link{font-size:.78rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;transition:color .3s;}.hznav__link:hover{color:var(--hz-text,#F5F0E8)!important;}.hznav__cta{padding:.5rem 1.1rem;border-radius:5px;font-weight:600;}@media(max-width:768px){.hznav__links{display:none;}}</style><div class=\"hznw\"><div class=\"hznav\"><a href=\"/\" class=\"hznav__logo\">Hazem Abdelbaset</a><div class=\"hznav__links\"><a href=\"/#work\" class=\"hznav__link\">Work</a><a href=\"/#about\" class=\"hznav__link\">About</a><a href=\"/#process\" class=\"hznav__link\">Process</a><a href=\"/start-project\" class=\"hznav__link hznav__cta\">Start a Project</a><button id=\"hz-tm\" class=\"hz-toggle\" aria-label=\"Toggle theme\">&#9728;</button></div></div></div><script>(function(){var btn=document.getElementById(\"hz-tm\");if(!btn)return;function upd(){var t=document.documentElement.getAttribute(\"data-theme\")||\"dark\";btn.innerHTML=t===\"dark\"?\"&#9728;\":\"&#9790;\";}upd();btn.addEventListener(\"click\",function(){var c=document.documentElement.getAttribute(\"data-theme\")||\"dark\";var n=c===\"dark\"?\"light\":\"dark\";document.documentElement.setAttribute(\"data-theme\",n);localStorage.setItem(\"hz-theme\",n);upd();});})();</script>"
