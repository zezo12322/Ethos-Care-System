              "settings": {
                "html": "<style id=\"hz-tokens\">\n/* ── DARK (default) ────────────────────────── */\n:root,[data-theme=dark]{\n  --hz-bg:     #1A1A1A;\n  --hz-bg-e:   #212121;\n  --hz-bg-c:   #212121;\n  --hz-bg-ph:  #171717;\n  --hz-text:   #F5F0E8;\n  --hz-text-s: rgba(245,240,232,.55);\n  --hz-text-t: rgba(245,240,232,.3);\n  --hz-text-d: rgba(245,240,232,.05);\n  --hz-green:  #20C997;\n  --hz-green-m:#56A176;\n  --hz-border: rgba(245,240,232,.08);\n  --hz-border-c:rgba(245,240,232,.12);\n  --hz-tag-bg: rgba(32,201,151,.07);\n  --hz-tag-bd: rgba(32,201,151,.12);\n  --hz-nav-bg: rgba(26,26,26,.97);\n  --hz-inp-bg: #212121;\n}\n/* ── LIGHT ──────────────────────────────────── */\n[data-theme=light]{\n  --hz-bg:     #F5F0E8;\n  --hz-bg-e:   #EAE5DD;\n  --hz-bg-c:   #E4DFD7;\n  --hz-bg-ph:  #D8D3CB;\n  --hz-text:   #1A1A1A;\n  --hz-text-s: rgba(26,26,26,.6);\n  --hz-text-t: rgba(26,26,26,.35);\n  --hz-text-d: rgba(26,26,26,.05);\n  --hz-green:  #1aad85;\n  --hz-green-m:#3d8a5f;\n  --hz-border: rgba(26,26,26,.1);\n  --hz-border-c:rgba(26,26,26,.15);\n  --hz-tag-bg: rgba(26,173,133,.07);\n  --hz-tag-bd: rgba(26,173,133,.2);\n  --hz-nav-bg: rgba(245,240,232,.97);\n  --hz-inp-bg: #EAE5DD;\n}\n/* ── AUTO (OS preference) ───────────────────── */\n@media(prefers-color-scheme:light){\n  :root:not([data-theme=dark]){\n    --hz-bg:#F5F0E8;--hz-bg-e:#EAE5DD;--hz-bg-c:#E4DFD7;--hz-bg-ph:#D8D3CB;\n    --hz-text:#1A1A1A;--hz-text-s:rgba(26,26,26,.6);--hz-text-t:rgba(26,26,26,.35);\n    --hz-text-d:rgba(26,26,26,.05);--hz-green:#1aad85;--hz-green-m:#3d8a5f;\n    --hz-border:rgba(26,26,26,.1);--hz-border-c:rgba(26,26,26,.15);\n    --hz-tag-bg:rgba(26,173,133,.07);--hz-tag-bd:rgba(26,173,133,.2);\n    --hz-nav-bg:rgba(245,240,232,.97);--hz-inp-bg:#EAE5DD;\n  }\n}\n\n/* ── TRANSITIONS ────────────────────────────── */\nbody,body *{transition:background-color .25s,border-color .25s,color .2s!important;}\n\n/* ── PAGE BACKGROUND ────────────────────────── */\nbody{background-color:var(--hz-bg)!important;}\n\n/* ── SECTION BACKGROUNDS ────────────────────── */\n.hz-bg-base{background-color:var(--hz-bg)!important;}\n.hz-bg-elevated{background-color:var(--hz-bg-e)!important;}\n\n/* ── CARD / COLUMN BACKGROUNDS ──────────────── */\n.hz-card,\n.hz-card>.elementor-column-wrap,\n.hz-card>.elementor-widget-wrap{\n  background-color:var(--hz-bg-c)!important;\n  border-color:var(--hz-border)!important;\n}\n\n/* ── HEADING WIDGET ─────────────────────────── */\n.elementor-widget-heading .elementor-heading-title{\n  color:var(--hz-text)!important;\n}\n.hz-accent .elementor-heading-title{color:var(--hz-green)!important;}\n\n/* ── TEXT-EDITOR WIDGET ─────────────────────── */\n.elementor-widget-text-editor p{color:var(--hz-text)!important;}\n.elementor-widget-text-editor span{color:inherit;}\n.elementor-widget-text-editor span[style*=\"#20C997\"]{color:var(--hz-green)!important;}\n.elementor-widget-text-editor span[style*=\"color:#20C997\"]{color:var(--hz-green)!important;}\n.elementor-widget-text-editor span[style*=\"rgba(245,240,232,.3)\"],\n.elementor-widget-text-editor span[style*=\"rgba(245,240,232, .3)\"]{\n  color:var(--hz-text-t)!important;\n}\n.elementor-widget-text-editor p[style*=\"rgba(245,240,232,.05)\"]{\n  color:var(--hz-text-d)!important;\n}\n.elementor-widget-text-editor p[style*=\"rgba(245,240,232,.5)\"],\n.elementor-widget-text-editor p[style*=\"rgba(245,240,232,.55)\"],\n.elementor-widget-text-editor p[style*=\"rgba(245,240,232,.45)\"],\n.elementor-widget-text-editor p[style*=\"rgba(245,240,232,.4)\"]{\n  color:var(--hz-text-s)!important;\n}\n\n/* ── ICON LIST ───────────────────────────────── */\n.elementor-widget-icon-list .elementor-icon-list-item .elementor-icon-list-text{\n  color:var(--hz-text-s)!important;\n}\n.elementor-widget-icon-list .elementor-icon-list-item i,\n.elementor-widget-icon-list .elementor-icon-list-item svg{\n  color:var(--hz-green)!important;\n  fill:var(--hz-green)!important;\n}\n\n/* ── DIVIDER ─────────────────────────────────── */\n.elementor-widget-divider .elementor-divider-separator{\n  border-color:var(--hz-border)!important;\n}\n\n/* ── NAV ─────────────────────────────────────── */\n.hznw{\n  position:sticky;top:0;z-index:100;\n  background:var(--hz-nav-bg)!important;\n  border-bottom:1px solid var(--hz-border)!important;\n  transition:box-shadow .3s,background .25s,border-color .25s!important;\n}\n.hznw.is-scrolled{box-shadow:0 1px 28px rgba(0,0,0,.35)!important;}\n.hznav a,.hznav__logo{color:var(--hz-text)!important;}\n.hznav__link{color:var(--hz-text-s)!important;}\n.hznav__cta{background:var(--hz-green)!important;color:#1A1A1A!important;}\n\n/* ── FOOTER ──────────────────────────────────── */\n.hzft{\n  background:var(--hz-bg)!important;\n  border-top:1px solid var(--hz-border)!important;\n}\n.hzft__name{color:var(--hz-text)!important;}\n.hzft__role,.hzft__tag{color:var(--hz-text-s)!important;}\n.hzft__links a{color:var(--hz-text-s)!important;}\n.hzft__links a:hover{color:var(--hz-green)!important;}\n\n/* ── FORM INPUTS ─────────────────────────────── */\n.hzfi,.hzfse,.hzfta{\n  background:var(--hz-inp-bg)!important;\n  border-color:var(--hz-border-c)!important;\n  color:var(--hz-text)!important;\n}\n.hzfi:focus,.hzfse:focus,.hzfta:focus{border-color:var(--hz-green)!important;}\n.hzfro label{\n  background:var(--hz-inp-bg)!important;\n  border-color:var(--hz-border-c)!important;\n  color:var(--hz-text-s)!important;\n}\n.hzfro input:checked+label{\n  border-color:var(--hz-green)!important;\n  color:var(--hz-green)!important;\n  background:var(--hz-tag-bg)!important;\n}\n.hzft2{color:var(--hz-text)!important;}\n.hzfs,.hzfh,.hzfnote{color:var(--hz-text-s)!important;}\n\n/* ── WORK CARD PLACEHOLDER ───────────────────── */\n.hz-ph{background:var(--hz-bg-ph)!important;}\n\n/* ── SERVICE TAG LABELS ──────────────────────── */\n.hz-svc-tag{\n  background:var(--hz-tag-bg)!important;\n  border-color:var(--hz-tag-bd)!important;\n  color:var(--hz-green)!important;\n}\n\n/* ── THEME TOGGLE BUTTON ─────────────────────── */\n.hz-toggle{\n  background:none;border:1px solid var(--hz-border);border-radius:6px;\n  padding:.38rem .55rem;cursor:pointer;color:var(--hz-text);\n  font-size:.95rem;line-height:1;margin-left:.75rem;\n  transition:border-color .3s,color .3s,background .3s!important;\n}\n.hz-toggle:hover{border-color:var(--hz-green);color:var(--hz-green);}\n\n/* ── SCROLL REVEAL ANIMATIONS ────────────────── */\n.reveal{\n  opacity:0;\n  transform:translateY(28px);\n  transition:opacity .75s cubic-bezier(.16,1,.3,1),\n             transform .75s cubic-bezier(.16,1,.3,1)!important;\n}\n.reveal.is-visible{\n  opacity:1!important;\n  transform:none!important;\n}\n.reveal--d1{transition-delay:.08s!important;}\n.reveal--d2{transition-delay:.2s!important;}\n.reveal--d3{transition-delay:.35s!important;}\n.reveal--d4{transition-delay:.52s!important;}\n</style>\n\n<script>\n/* 1. Restore theme before first paint (runs sync) */\n(function(){\n  var saved=localStorage.getItem('hz-theme');\n  var auto=window.matchMedia('(prefers-color-scheme:light)').matches?'light':'dark';\n  document.documentElement.setAttribute('data-theme',saved||auto);\n})();\n\n/* 2. Animations — run after DOM ready */\ndocument.addEventListener('DOMContentLoaded',function(){\n\n  /* Scroll reveal */\n  if('IntersectionObserver' in window){\n    var obs=new IntersectionObserver(function(entries){\n      entries.forEach(function(e){\n        if(e.isIntersecting){e.target.classList.add('is-visible');obs.unobserve(e.target);}\n      });\n    },{threshold:.1,rootMargin:'0px 0px -40px 0px'});\n    document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el);});\n  } else {\n    /* Fallback: show everything immediately */\n    document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('is-visible');});\n  }\n\n  /* Nav scroll shadow */\n  window.addEventListener('scroll',function(){\n    var nav=document.querySelector('.hznw');\n    if(!nav)return;\n    nav.classList.toggle('is-scrolled',window.scrollY>60);\n  },{passive:true});\n\n  /* Cursor glow — desktop only */\n  if(window.matchMedia('(pointer:fine)').matches){\n    var g=document.createElement('div');\n    g.style.cssText=\n      'position:fixed;width:400px;height:400px;border-radius:50%;pointer-events:none;'\n      +'background:radial-gradient(circle,rgba(32,201,151,.04) 0%,transparent 70%);'\n      +'transform:translate(-50%,-50%);z-index:0;'\n      +'transition:left .6s cubic-bezier(.16,1,.3,1),top .6s cubic-bezier(.16,1,.3,1);'\n      +'left:-500px;top:-500px;';\n    document.body.appendChild(g);\n    document.addEventListener('mousemove',function(e){\n      g.style.left=e.clientX+'px';\n      g.style.top=e.clientY+'px';\n    },{passive:true});\n  }\n});\n</script>"
              },
