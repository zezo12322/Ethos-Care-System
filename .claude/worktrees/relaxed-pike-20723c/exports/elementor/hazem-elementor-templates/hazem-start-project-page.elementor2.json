        "background_color": "#1A1A1A",
        "padding": {
          "unit": "px",
          "top": "0",
          "right": "20",
          "bottom": "60",
          "left": "20",
          "isLinked": false
        },
        "gap": "default",
        "css_classes": "hz-bg-base"
      },
      "elements": [
        {
          "id": "e1622cc2",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "_inline_size": null,
