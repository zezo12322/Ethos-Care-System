generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  name          String
  role          String        @default("CASE_WORKER")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  assignedCases Case[]
  actions       CaseHistory[]
  news          News[]
}

model Case {
  id                      String        @id @default(uuid())
  applicantName           String
  nationalId              String?
  caseType                String        @default("غير محدد")
  status                  String        @default("قيد المراجعة")
  lifecycleStatus         String        @default("DRAFT")
  completenessStatus      String        @default("MISSING_DOCUMENTS")
  decisionStatus          String        @default("PENDING_DECISION")
  priority                String        @default("NORMAL")
  location                String        @default("بني سويف")
  description             String?
  formData                Json?
  familyId                String?
  assignedToId            String?
  operationId             String?
  requiresCommitteeReview Boolean       @default(false)
  lastActionAt            DateTime      @default(now())
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  assignedTo              User?         @relation(fields: [assignedToId], references: [id])
  family                  Family?       @relation(fields: [familyId], references: [id])
  operation               Operation?    @relation(fields: [operationId], references: [id])
  history                 CaseHistory[]

  @@index([lifecycleStatus])
  @@index([priority, lifecycleStatus])
  @@index([completenessStatus])
  @@index([familyId])
  @@index([assignedToId])
  @@index([operationId])
  @@index([createdAt])
}

model CaseHistory {
  id                  String   @id @default(uuid())
  caseId              String
  fromLifecycleStatus String?
  toLifecycleStatus   String
  fromDecisionStatus  String?
  toDecisionStatus    String
  action              String
  reason              String?
  performedById       String?
  metadataJson        String?
  performedAt         DateTime @default(now())
  case                Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  performedBy         User?    @relation(fields: [performedById], references: [id])

  @@index([caseId, performedAt])
  @@index([performedById])
}

model Family {
  id             String         @id @default(uuid())
  headName       String
  nationalId     String?        @unique
  phone          String?
  socialStatus   String         @default("متزوج/ة")
  job            String?
  income         String?
  city           String         @default("بني سويف - المركز")
  village        String?
  addressDetails String?
  address        String?
  membersCount   Int            @default(1)
  status         String         @default("تحت التقييم")
  lastVisit      DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  education      String?
  cases          Case[]
  familyMembers  FamilyMember[]

  @@index([status])
}

model Operation {
  id         String   @id @default(uuid())
  name       String
  type       String
  date       DateTime @default(now())
  target     Int      @default(0)
  achieved   Int      @default(0)
  status     String   @default("تجهيز")
  progress   Int      @default(0)
  volunteers Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cases      Case[]
  volunteerAssignments VolunteerAssignment[]
}

model Volunteer {
  id            String                @id @default(uuid())
  name          String
  phone         String?
  email         String?
  age           Int?
  preferredArea String?               // النشاط / مجال التطوع المفضل
  skills        String?               // المهارات / الاهتمامات
  status        String                @default("PENDING") // PENDING | ACTIVE | INACTIVE | REJECTED
  notes         String?
  source        String                @default("MANUAL")  // MANUAL | PUBLIC_FORM
  // حقول استمارة التطوع الموسّعة
  nationalId    String?
  birthDate     String?
  education     String?               // المؤهل الدراسي
  schoolYear    String?               // السنة الدراسية
  center        String?               // المركز
  whatsapp      String?               // رقم الواتساب
  address       String?               // العنوان بالتفصيل
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  assignments   VolunteerAssignment[]

  @@index([status])
  @@index([nationalId])
  @@index([phone])
}

model VolunteerAssignment {
  id          String    @id @default(uuid())
  volunteerId String
  operationId String
  role        String?   // دور المتطوع في النشاط
  attended    Boolean   @default(false)
  hours       Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, operationId])
  @@index([operationId])
}

model Partner {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("مؤسسة مانحة")
  contact   String?
  email     String?
  status    String   @default("نشط")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     String?
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String   @default("فعاليات")
  image     String?
  date      DateTime @default(now())
  published Boolean  @default(true)
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User?    @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([published, date])
}

model Location {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("قرية")
  region    String   @default("بني سويف")
  status    String   @default("مفعل")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FamilyMember {
  id             String   @id @default(uuid())
  name           String
  relation       String   @default("ابن/ة")
  age            String?
  education      String?  @default("لا يدرس")
  // حقول إضافية حتى يصبح ملف الأسرة المصدر الكامل لبيانات الأفراد
  nationalId     String?
  gender         String?
  mobile         String?
  job            String?
  monthlyIncome  String?  @default("0")
  classification String?
  educationType  String?
  educationStage String?
  schoolYear     String?
  familyId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  family         Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

// ─── CMS Models ───────────────────────────────────────────────────────────────

model ServiceType {
  id        String   @id @default(uuid())
  name      String
  category  String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentType {
  id        String   @id @default(uuid())
  name      String
  required  Boolean  @default(false)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DropdownOption {
  id        String   @id @default(uuid())
  category  String
  value     String
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value])
}

model SystemConfig {
  key       String   @id
  value     String
  type      String   @default("string")
  label     String?
  group     String?
  updatedAt DateTime @updatedAt
}

model SiteContent {
  key       String   @id
  value     String
  label     String?
  group     String?
  updatedAt DateTime @updatedAt
}

model Campaign {
  id          String   @id @default(uuid())
  title       String
  description String
  target      Int      @default(0)
  raised      Int      @default(0)
  category    String
  icon        String
  color       String   @default("bg-primary")
  lightColor  String   @default("bg-primary/10")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Program {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String
  accent      String   @default("text-primary")
  bg          String   @default("bg-primary/10")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
